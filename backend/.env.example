# ----------------------------------------------------------------------------
# MyPipelineHero local-dev environment template.
# Copy this file to backend/.env and adjust as needed.
# Production secrets MUST come from your secret store, not from this file.
# ----------------------------------------------------------------------------

# Django settings module for local dev
DJANGO_SETTINGS_MODULE=config.settings.dev

# Django
DJANGO_SECRET_KEY=dev-only-not-secret-replace-in-every-non-dev-env
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=mph.local,*.mph.local,localhost,127.0.0.1,web

# Domain configuration (used in M1+; harmless in M0)
MPH_ROOT_DOMAIN=mph.local
MPH_TENANT_DOMAIN_TEMPLATE={slug}.mph.local

# Database
DATABASE_URL=postgres://mph:mph@postgres:5432/mph

# Redis (broker, cache, handoff token store, rate limits)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Email (Mailpit for local dev)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=noreply@mph.local

# Object storage (MinIO for local dev; S3-compatible)
OBJECT_STORE_ENDPOINT=http://minio:9000
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_ACCESS_KEY=mph-dev
OBJECT_STORE_SECRET_KEY=mph-dev-secret
OBJECT_STORE_BUCKET=mph-dev

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Misc
TIME_ZONE=America/Chicago
LANGUAGE_CODE=en-us
