# Force LF line endings for shell scripts and other Linux-targeted files,
# even when checked out on Windows with core.autocrlf=true.
*.sh             text eol=lf
Dockerfile       text eol=lf
Dockerfile.*     text eol=lf
*.dockerfile     text eol=lf
docker-compose*  text eol=lf
compose*.yaml    text eol=lf
compose*.yml     text eol=lf
*.conf           text eol=lf

# Treat lockfiles as text but without conversion.
package-lock.json text eol=lf
yarn.lock         text eol=lf