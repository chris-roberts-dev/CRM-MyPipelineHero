# MyPipelineHero frontend npm config.
#
# `node_modules/` is installed on the HOST (Windows/macOS/Linux) and
# bind-mounted into the Vite container (Linux Alpine). For native modules
# like @rollup/rollup-*, lightningcss-*, and @tailwindcss/oxide-* this
# means we need binaries for BOTH the host platform AND the container
# platform present on disk.
#
# The settings below ask npm to fetch optional dependencies for every
# supported architecture, not just the one we're running on. The
# binaries are small (~5-10 MB each) and dormant when not loaded.
#
# Without this, an `npm install` on Windows produces a node_modules
# directory that fails to load Rollup inside the Linux container:
#   Cannot find module '@rollup/rollup-linux-x64-musl'

# Standard niceties.
fund = false
audit = false
loglevel = warn

# Use lockfile reproducibility when present.
package-lock = true
save-exact = false